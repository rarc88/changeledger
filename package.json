{
  "name": "spec-ledger",
  "version": "0.1.0",
  "description": "Plan before coding. Documents are the source of truth; code is their reflection.",
  "type": "module",
  "bin": {
    "sl": "bin/sl.mjs"
  },
  "scripts": {
    "lint": "biome check",
    "format": "biome check --write",
    "test": "node --test",
    "check": "node bin/sl.mjs check",
    "verify": "pnpm lint && pnpm test && pnpm check"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "templates"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{js,mjs,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "lint-staged": "^17.0.7"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "mermaid": "^11.15.0"
  }
}
